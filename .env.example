# Binance
BINANCE_FUTURES_WS=wss://fstream.binance.com
BINANCE_SPOT_WS=wss://stream.binance.com:9443

# Auth
JWT_SECRET=
SESSION_EXPIRY=24h

# Frontend
VITE_API_URL=http://localhost:8080
